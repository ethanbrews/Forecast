<ContentDialog
    x:Class="ForecastUWP.Dialogs.ProfileInstallationError"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ForecastUWP.Dialogs"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Error Installing Profile"
    PrimaryButtonText="Close"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick">

    <StackPanel>
        <TextBlock TextWrapping="WrapWholeWords" Margin="0 0 0 20" Style="{StaticResource BaseTextBlockStyle}">Couldn't install <Run x:Name="ProfileNameRun" /></TextBlock>
        <TextBlock TextWrapping="WrapWholeWords" Style="{StaticResource BodyTextBlockStyle}">Error Description: <Run x:Name="ErrorDescriptionRun" /></TextBlock>
    </StackPanel>
</ContentDialog>
